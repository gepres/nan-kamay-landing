---
// 404 + VISOR WEB EN VIVO (PR3) para quien NO tiene la app.
// En Android/iOS con la app instalada y verificada, el App Link abre la app
// directo y esta página nunca se ve. En el navegador (sin app), `/seguir/<token>`
// cae al 404.html y aquí mostramos el mapa en vivo leyendo el RPC
// nk_get_live_session(token) con la publishable key (anon). El token va en la URL.
import { withBase } from '../i18n/utils';
import { SITE } from '../config';
const logo = withBase('/icon.png');
const home = withBase('/');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Ñan Kamay — Seguimiento en vivo</title>
    <meta name="theme-color" content="#0D1B12" />
    <link rel="icon" type="image/png" href={withBase('/favicon.png')} />
    <style>
      :root { --night:#0d1b12; --card:#1b4332; --line:#2d6a4f; --accent:#f59e0b; --ink:#fff; --soft:#a7c4b5; --muted:#6b8f7b; }
      * { box-sizing: border-box; }
      html, body { height: 100%; }
      body { margin:0; background:var(--night); color:var(--ink);
             font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif; }
      .hidden { display:none !important; }
      .btn { display:flex; align-items:center; justify-content:center; gap:8px; padding:12px;
             border-radius:12px; font-weight:800; font-size:14px; text-decoration:none; border:1px solid transparent; }
      .btn-primary { background:var(--accent); color:var(--night); }
      .btn-ghost { background:transparent; border-color:var(--line); color:var(--ink); }

      /* ---- Visor ---- */
      .viewer { min-height:100dvh; display:flex; flex-direction:column; }
      .vhead { display:flex; align-items:center; gap:11px; padding:13px 16px; border-bottom:1px solid var(--line); }
      .vhead img { width:36px; height:36px; border-radius:9px; }
      .vtitle { font-weight:800; font-size:16px; display:flex; align-items:center; gap:7px; line-height:1.1; }
      .vstatus { color:var(--soft); font-size:12.5px; margin-top:3px; }
      .dot { width:9px; height:9px; border-radius:50%; background:#22c55e; display:inline-block;
             animation:pulse 2s infinite; }
      @keyframes pulse { 0%{box-shadow:0 0 0 0 rgba(34,197,94,.5)} 70%{box-shadow:0 0 0 9px rgba(34,197,94,0)} 100%{box-shadow:0 0 0 0 rgba(34,197,94,0)} }
      /* El mapa SIEMPRE se muestra; un overlay informa mientras no haya posición */
      #mapwrap { flex:1; min-height:300px; position:relative; }
      #map { position:absolute; inset:0; background:#0a140e; }
      #overlay { position:absolute; top:12px; left:50%; transform:translateX(-50%); z-index:500;
                 background:rgba(13,27,18,.92); border:1px solid var(--line); border-radius:999px;
                 padding:8px 14px; font-size:12.5px; color:var(--soft); max-width:90%; text-align:center;
                 box-shadow:0 4px 14px rgba(0,0,0,.35); }
      .vfoot { padding:13px 16px; border-top:1px solid var(--line); display:flex; flex-direction:column; gap:9px; }
      .vmeta { color:var(--soft); font-size:13px; min-height:18px; }
      .vdiag { color:var(--muted); font-size:11.5px; }
      .vbtns { display:flex; gap:10px; }
      .vbtns .btn { flex:1; }
      /* El marcador se dibuja con L.circleMarker (SVG por JS), NO con CSS: una
         clase aquí la "scopea" Astro con [data-astro-cid] y el nodo que inyecta
         Leaflet en runtime no la lleva → quedaría invisible. */
      .badge { position:fixed; top:8px; right:10px; z-index:900; font-size:10px; color:var(--muted);
               background:rgba(13,27,18,.6); border:1px solid var(--line); border-radius:6px; padding:2px 6px; }

      /* ---- 404 genérico ---- */
      .wrap404 { min-height:100dvh; display:grid; place-items:center; padding:24px; }
      .card { width:100%; max-width:420px; background:rgba(27,67,50,.35); border:1px solid var(--line);
              border-radius:20px; padding:28px; text-align:center; }
      .card img { width:64px; height:64px; border-radius:14px; margin:0 auto 16px; display:block; }
      .card h1 { font-size:20px; margin:0 0 8px; font-weight:800; }
      .card p { color:var(--soft); font-size:14px; line-height:1.5; margin:0 0 14px; }
    </style>
  </head>
  <body>
    <span class="badge" id="ver">visor v4</span>

    <!-- VISOR EN VIVO (se muestra si la URL es /seguir/<token>) -->
    <div id="follow" class="viewer hidden">
      <div class="vhead">
        <img src={logo} alt="" width="36" height="36" />
        <div>
          <div class="vtitle"><span class="dot"></span><span id="owner">Seguimiento en vivo</span></div>
          <div class="vstatus" id="status">Conectando…</div>
        </div>
      </div>
      <div id="mapwrap">
        <div id="map"></div>
        <div id="overlay">Cargando el mapa…</div>
      </div>
      <div class="vfoot">
        <div class="vmeta" id="meta"></div>
        <div class="vdiag" id="diag"></div>
        <div class="vbtns">
          <a id="open" class="btn btn-primary" href="#">Abrir en Ñan Kamay</a>
          <a id="install" class="btn btn-ghost" href={SITE.downloadUrl} target="_blank" rel="noopener">Instalar la app</a>
        </div>
      </div>
    </div>

    <!-- 404 genérico -->
    <div id="generic" class="wrap404 hidden">
      <div class="card">
        <img src={logo} alt="Ñan Kamay" width="64" height="64" />
        <h1>Página no encontrada</h1>
        <p>Este enlace no existe o ya expiró.</p>
        <a class="btn btn-primary" href={home}>Ir al inicio</a>
      </div>
    </div>

    <script is:inline define:vars={{ SUPABASE_URL: SITE.supabaseUrl, SUPABASE_ANON_KEY: SITE.supabaseAnonKey }}>
      (function () {
        var path = location.pathname.replace(/\/+$/, '');
        var m = path.match(/\/seguir\/([^\/]+)$/);
        var UUID = /^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;

        if (!(m && UUID.test(m[1]))) {
          document.getElementById('generic').classList.remove('hidden');
          return;
        }
        var token = m[1];
        document.getElementById('follow').classList.remove('hidden');

        // "Abrir en la app" (por si tiene la app pero cayó al navegador)
        var playUrl = document.getElementById('install').getAttribute('href');
        document.getElementById('open').setAttribute('href',
          /Android/i.test(navigator.userAgent)
            ? 'intent://nankamay.trek-peru.com/seguir/' + token + '#Intent;scheme=https;package=com.gepres.nankamay;S.browser_fallback_url=' + encodeURIComponent(playUrl) + ';end'
            : 'nan-kamay://seguir/' + token);

        var statusEl = document.getElementById('status');
        var metaEl = document.getElementById('meta');
        var ownerEl = document.getElementById('owner');
        var diagEl = document.getElementById('diag');
        var overlayEl = document.getElementById('overlay');
        var map = null, marker = null, accCircle = null, centered = false, lastAt = null, ended = false, timer = null, mapReady = false;

        function setStatus(t) { statusEl.textContent = t; }
        function setDiag(t) { diagEl.textContent = t; }
        function showOverlay(t) { if (t) { overlayEl.textContent = t; overlayEl.classList.remove('hidden'); } else { overlayEl.classList.add('hidden'); } }
        function fmtAgo(d) {
          if (!d) return '';
          var s = Math.max(0, Math.floor((Date.now() - d.getTime()) / 1000));
          if (s < 60) return 'hace ' + s + ' s';
          var mn = Math.floor(s / 60);
          if (mn < 60) return 'hace ' + mn + ' min';
          return 'hace ' + Math.floor(mn / 60) + ' h';
        }
        function fmtDist(mts) {
          if (mts == null) return '—';
          return mts >= 1000 ? (mts / 1000).toFixed(2) + ' km' : Math.round(mts) + ' m';
        }
        function loadLeaflet() {
          return new Promise(function (resolve, reject) {
            var css = document.createElement('link');
            css.rel = 'stylesheet';
            css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
            document.head.appendChild(css);
            var js = document.createElement('script');
            js.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
            js.onload = resolve; js.onerror = reject;
            document.head.appendChild(js);
          });
        }
        function initMap() {
          // Mapa visible de inmediato (vista regional Perú); se centra al llegar la 1ª posición.
          map = L.map('map', { zoomControl: true }).setView([-12.0, -75.5], 5);
          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19, attribution: '© OpenStreetMap'
          }).addTo(map);
          mapReady = true;
          setTimeout(function () { map.invalidateSize(); }, 200);
        }
        function update(s) {
          var who = (s.owner_name || '').trim() || 'Tu contacto';
          ownerEl.textContent = who;
          ended = s.status === 'ended';
          lastAt = s.last_at ? new Date(s.last_at) : null;
          var hasPos = s.last_lat != null && s.last_lon != null;
          if (hasPos && mapReady) {
            var ll = [s.last_lat, s.last_lon];
            // Marcador SVG (sin CSS/clase → inmune al scoping de Astro).
            if (!marker) {
              marker = L.circleMarker(ll, { radius: 9, color: '#0d1b12', weight: 3, fillColor: '#f59e0b', fillOpacity: 1 }).addTo(map);
            } else {
              marker.setLatLng(ll);
            }
            // Círculo de precisión (si el emisor lo envía).
            if (s.last_accuracy != null) {
              if (!accCircle) accCircle = L.circle(ll, { radius: s.last_accuracy, color: '#f59e0b', weight: 1, fillColor: '#f59e0b', fillOpacity: 0.12 }).addTo(map);
              else { accCircle.setLatLng(ll); accCircle.setRadius(s.last_accuracy); }
            }
            if (!centered) { map.setView(ll, 15); centered = true; }
            else { map.panTo(ll); }
            map.invalidateSize();
            showOverlay(null);
          } else if (!hasPos) {
            showOverlay(ended ? (who + ' finalizó su recorrido') : ('Esperando la primera posición de ' + who + '…'));
          }
          var acc = s.last_accuracy != null ? ' · ±' + Math.round(s.last_accuracy) + ' m' : '';
          metaEl.textContent = hasPos ? ('Distancia: ' + fmtDist(s.distance_meters) + acc) : '';
          setStatus(ended ? (who + ' finalizó') : (hasPos ? ('Siguiendo a ' + who + ' · ' + fmtAgo(lastAt)) : ('Conectado · ' + who)));
        }
        async function fetchSession() {
          var res = await fetch(SUPABASE_URL + '/rest/v1/rpc/nk_get_live_session', {
            method: 'POST',
            headers: { 'apikey': SUPABASE_ANON_KEY, 'Authorization': 'Bearer ' + SUPABASE_ANON_KEY, 'Content-Type': 'application/json' },
            body: JSON.stringify({ p_token: token })
          });
          if (!res.ok) throw new Error('HTTP ' + res.status);
          var rows = await res.json();
          return Array.isArray(rows) ? rows[0] : rows;
        }
        async function poll() {
          try {
            var s = await fetchSession();
            if (!s) {
              setStatus('Enlace no disponible o expiró');
              showOverlay('Este enlace no existe o ya expiró (los enlaces duran 12 h).');
              setDiag('RPC: sesión no encontrada para este token.');
              return;
            }
            update(s);
            var hasPos = s.last_lat != null && s.last_lon != null;
            setDiag(hasPos ? ('Última posición ' + fmtAgo(lastAt) + '.') : 'Sesión activa, aún sin posición (el emisor debe estar grabando con "Compartir en vivo").');
            if (ended && timer) { clearInterval(timer); timer = null; }
          } catch (e) {
            setStatus('Sin conexión. Reintentando…');
            setDiag('Error al consultar: ' + (e && e.message ? e.message : e));
          }
        }
        setStatus('Conectando…');
        setDiag('Conectando con el servidor…');
        loadLeaflet().then(function () {
          initMap();
          showOverlay('Buscando la ubicación en vivo…');
          poll();
          timer = setInterval(poll, 10000);
          setInterval(function () { if (!ended && lastAt) setStatus('Siguiendo a ' + ownerEl.textContent + ' · ' + fmtAgo(lastAt)); }, 1000);
        }).catch(function () {
          showOverlay('No se pudo cargar el mapa (sin acceso al CDN). Revisa tu conexión.');
          setStatus('No se pudo cargar el mapa.');
          // Aun sin mapa, seguimos sondeando para mostrar estado/posición textual.
          poll();
          timer = setInterval(poll, 10000);
        });
      })();
    </script>
  </body>
</html>
