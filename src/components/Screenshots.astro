---
import { getLangFromUrl } from '../i18n/utils';
import { content } from '../i18n/content';
import PhoneMockup from './PhoneMockup.astro';

const lang = getLangFromUrl(Astro.url);
const t = content[lang];
const icons = ['lucide:navigation', 'lucide:map', 'lucide:flag', 'lucide:git-branch'];
---

<section class="scroll-mt-20 border-y border-line/40 bg-card/20 py-20 sm:py-28">
  <div class="mx-auto max-w-6xl px-5">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="font-display text-3xl font-extrabold tracking-tight sm:text-4xl">{t.screens.heading}</h2>
      <p class="mt-3 text-lg text-ink-soft">{t.screens.subheading}</p>
    </div>

    <div class="reveal mt-14 flex snap-x snap-mandatory gap-6 overflow-x-auto pb-4 sm:grid sm:grid-cols-2 sm:overflow-visible lg:grid-cols-4">
      {t.screens.shots.map((s, i) => (
        <figure class="shrink-0 snap-center">
          <PhoneMockup label={s.caption} icon={icons[i]} />
          <figcaption class="mt-4 text-center text-sm font-medium text-ink-soft">{s.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
