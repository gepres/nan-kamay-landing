---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl } from '../i18n/utils';
import { content } from '../i18n/content';
import PhoneMockup from './PhoneMockup.astro';

const lang = getLangFromUrl(Astro.url);
const t = content[lang];

const mockMeta: Record<string, { icon: string; id?: string }> = {
  offline: { icon: 'lucide:map' },
  safety: { icon: 'lucide:shield-check', id: 'seguridad' },
};
---

<section class="py-8">
  <div class="mx-auto flex max-w-6xl flex-col gap-20 px-5 py-12 sm:gap-28">
    {t.highlights.map((h, i) => {
      const meta = mockMeta[h.mock] ?? { icon: 'lucide:navigation' };
      const flip = i % 2 === 1;
      return (
        <div id={meta.id} class="reveal scroll-mt-20 grid items-center gap-10 md:grid-cols-2">
          <div class={flip ? 'md:order-2' : ''}>
            <span class="text-sm font-bold uppercase tracking-widest text-accent">{h.eyebrow}</span>
            <h2 class="mt-3 font-display text-3xl font-extrabold tracking-tight sm:text-4xl">{h.title}</h2>
            <p class="mt-4 text-lg leading-relaxed text-ink-soft">{h.desc}</p>
            <ul class="mt-6 space-y-3">
              {h.bullets.map((b) => (
                <li class="flex items-start gap-3 text-ink">
                  <Icon name="lucide:check" class="mt-0.5 h-5 w-5 shrink-0 text-easy" />
                  <span class="text-[15px]">{b}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class={`flex justify-center ${flip ? 'md:order-1 md:justify-start' : 'md:justify-end'}`}>
            <PhoneMockup label={h.eyebrow} icon={meta.icon} class={flip ? '-rotate-[2deg]' : 'rotate-[2deg]'} />
          </div>
        </div>
      );
    })}
  </div>
</section>
