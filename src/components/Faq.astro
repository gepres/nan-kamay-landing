---
import { Icon } from 'astro-icon/components';
import { getLangFromUrl } from '../i18n/utils';
import { content } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const t = content[lang];
---

<section id="preguntas" class="scroll-mt-20 py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-5">
    <h2 class="reveal text-center font-display text-3xl font-extrabold tracking-tight sm:text-4xl">{t.faq.heading}</h2>

    <div class="reveal mt-12 space-y-3">
      {t.faq.items.map((item) => (
        <details class="group rounded-xl border border-line/60 bg-card/40 px-5 open:bg-card/70">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 font-semibold text-ink [&::-webkit-details-marker]:hidden">
            {item.q}
            <Icon name="lucide:chevron-down" class="h-5 w-5 shrink-0 text-accent transition group-open:rotate-180" />
          </summary>
          <p class="pb-5 text-[15px] leading-relaxed text-ink-soft">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
