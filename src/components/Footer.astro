---
import { getLangFromUrl, base, withBase } from '../i18n/utils';
import { content } from '../i18n/content';
import { SITE } from '../config';

const lang = getLangFromUrl(Astro.url);
const t = content[lang];
const home = withBase(base(lang) ? base(lang) + '/' : '/');
const logo = withBase('/icon.png');
const year = 2026;
const privacyHref = withBase(lang === 'en' ? '/en/privacy' : '/privacidad');
const privacyLabel = lang === 'en' ? 'Privacy' : 'Privacidad';
---

<footer class="border-t border-line/40 bg-card/20">
  <div class="mx-auto grid max-w-6xl gap-10 px-5 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div class="lg:col-span-2">
      <a href={home} class="flex items-center gap-2.5">
        <img src={logo} alt="" width="32" height="32" class="h-8 w-8 rounded-lg" />
        <span class="font-display text-lg font-extrabold tracking-tight">Ñan Kamay</span>
      </a>
      <p class="mt-3 max-w-xs text-sm text-ink-soft">{t.footer.tagline}</p>
      <p class="mt-2 text-sm text-ink-muted">{t.footer.madeIn}</p>
    </div>

    {t.footer.cols.map((col) => (
      <div>
        <h3 class="text-xs font-bold uppercase tracking-widest text-ink-muted">{col.title}</h3>
        <ul class="mt-4 space-y-2.5">
          {col.links.map((l) => (
            <li><a href={l.href} class="text-sm text-ink-soft transition hover:text-accent">{l.label}</a></li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="border-t border-line/40">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-5 py-5 text-sm text-ink-muted sm:flex-row">
      <span>© {year} {SITE.name}. {t.footer.rights}</span>
      <div class="flex items-center gap-4">
        <a href={privacyHref} class="transition hover:text-accent">{privacyLabel}</a>
        <a href={SITE.website} target="_blank" rel="noopener" class="transition hover:text-accent">genaropretill.com</a>
      </div>
    </div>
  </div>
</footer>
