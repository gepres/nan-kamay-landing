---
import '@fontsource-variable/sora';
import '@fontsource-variable/inter';
import '../styles/global.css';
import { SITE } from '../config';
import { getLangFromUrl, altLang, withBase, stripBase } from '../i18n/utils';
import { content } from '../i18n/content';

const lang = getLangFromUrl(Astro.url);
const t = content[lang];
const alt = altLang(Astro.url);

// URLs absolutas a partir de `Astro.site` (definido en astro.config) + el prefijo
// de despliegue. Así canonical/OG/hreflang son correctos tanto en la project page
// (/nan-kamay-landing/) como en un dominio propio en la raíz.
const canonical = new URL(withBase(stripBase(Astro.url.pathname)), Astro.site).href;
const altHref = new URL(alt.path, Astro.site).href;
const siteRoot = new URL(withBase('/'), Astro.site).href;
const ogImage = new URL(withBase('/og.png'), Astro.site).href;

// Datos estructurados (schema.org) — ayuda a buscadores a entender que es una
// app móvil gratuita.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: SITE.name,
  description: t.meta.description,
  applicationCategory: 'TravelApplication',
  operatingSystem: 'Android',
  url: siteRoot,
  image: ogImage,
  inLanguage: lang,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: { '@type': 'Organization', name: SITE.name },
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={lang} href={canonical} />
    <link rel="alternate" hreflang={alt.lang} href={altHref} />
    <link rel="alternate" hreflang="x-default" href={siteRoot} />

    <link rel="icon" type="image/png" href={withBase('/favicon.png')} />
    <link rel="apple-touch-icon" href={withBase('/icon.png')} />
    <link rel="manifest" href={withBase('/site.webmanifest')} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <meta name="theme-color" content="#0D1B12" />
    <meta name="author" content="Ñan Kamay" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t.meta.title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.meta.title} />
    <meta name="twitter:description" content={t.meta.description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body class="font-sans antialiased">
    <slot />

    <script>
      // Revelado progresivo al hacer scroll. Sin JS, todo se muestra igual.
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window && els.length) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('in'));
      }
    </script>
  </body>
</html>
